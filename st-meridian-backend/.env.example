# ============================================================
# St. Meridian Academy ERP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Firebase Admin SDK — paste contents of your serviceAccountKey.json here
# OR set GOOGLE_APPLICATION_CREDENTIALS to the path of that file.

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5501,http://localhost:5500,http://127.0.0.1:5501
